# Comma-separated bearer tokens, optionally bound to an agent name: token[:agentName]
MCS_TOKENS=tok_local_dev:local-dev

# Redis connection
REDIS_URL=redis://localhost:6379

# Default per-stream retention (approximate XTRIM MAXLEN)
MCS_STREAM_MAXLEN=10000

# HTTP port (MCP endpoint + ingest + healthz)
PORT=3000
