# Comma-separated bearer tokens: token[:agentName[:admin]]
# The admin role gates configure_stream, webhooks, and federation management.
# Empty = no auth AND every session is admin — local dev only.
MCS_TOKENS=tok_ops:ops:admin,tok_agent:fleet-agent

# Redis connection
REDIS_URL=redis://localhost:6379

# Default per-stream retention (approximate XTRIM MAXLEN; per-stream override
# via the configure_stream tool)
MCS_STREAM_MAXLEN=10000

# HTTP port (MCP endpoint + ingest + healthz + metrics)
PORT=3000
